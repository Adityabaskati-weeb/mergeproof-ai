{
  "name": "mergeproof-vscode",
  "displayName": "MergeProof Evidence Review",
  "description": "Run evidence-backed MergeProof reviews from VS Code.",
  "version": "0.1.0",
  "publisher": "mergeproof",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters", "Other"],
  "main": "extension.js",
  "activationEvents": ["onStartupFinished", "onCommand:mergeproof.analyzePullRequest", "onCommand:mergeproof.viewPullRequest", "onCommand:mergeproof.consensus", "onCommand:mergeproof.reviewWorkingTree", "onCommand:mergeproof.resolveConflicts", "onCommand:mergeproof.resolveReviewThreads", "onCommand:mergeproof.runSandboxAgent", "onCommand:mergeproof.autopilot", "onCommand:mergeproof.implementIssue", "onCommand:mergeproof.generatePlan", "onCommand:mergeproof.generateWorkPlan", "onCommand:mergeproof.securityScan", "onCommand:mergeproof.planHistory", "onCommand:mergeproof.verifyBundle", "onCommand:mergeproof.generateWalkthrough", "onCommand:mergeproof.generateDocstrings", "onCommand:mergeproof.suggestFix", "onCommand:mergeproof.simplify", "onCommand:mergeproof.generateTests", "onCommand:mergeproof.autofix"],
  "contributes": {
    "commands": [
      { "command": "mergeproof.analyzePullRequest", "title": "MergeProof: Analyze Pull Request" },
      { "command": "mergeproof.viewPullRequest", "title": "MergeProof: View Pull Request" },
      { "command": "mergeproof.consensus", "title": "MergeProof: Run Consensus Gate" },
      { "command": "mergeproof.resolveConflicts", "title": "MergeProof: Resolve Merge Conflicts" },
      { "command": "mergeproof.resolveReviewThreads", "title": "MergeProof: Resolve Review Threads" },
      { "command": "mergeproof.generateDocstrings", "title": "MergeProof: Generate Docstrings" },
      { "command": "mergeproof.reviewWorkingTree", "title": "MergeProof: Review Working Tree" },
      { "command": "mergeproof.runSandboxAgent", "title": "MergeProof: Run Sandbox Agent" },
      { "command": "mergeproof.autopilot", "title": "MergeProof: Run Autopilot Correction Loop" },
      { "command": "mergeproof.implementIssue", "title": "MergeProof: Implement GitHub Issue" },
      { "command": "mergeproof.generatePlan", "title": "MergeProof: Generate Evidence Plan" },
      { "command": "mergeproof.generateWorkPlan", "title": "MergeProof: Plan Free-form Work Item" },
      { "command": "mergeproof.securityScan", "title": "MergeProof: Scan Repository Security" },
      { "command": "mergeproof.planHistory", "title": "MergeProof: Inspect Plan History" },
      { "command": "mergeproof.verifyBundle", "title": "MergeProof: Verify Review Capsule" },
      { "command": "mergeproof.generateWalkthrough", "title": "MergeProof: Generate PR Walkthrough" },
      { "command": "mergeproof.suggestFix", "title": "MergeProof: Suggest Safe Fix" },
      { "command": "mergeproof.simplify", "title": "MergeProof: Simplify Changed Code" },
      { "command": "mergeproof.generateTests", "title": "MergeProof: Generate Test Patch" },
      { "command": "mergeproof.autofix", "title": "MergeProof: Autofix Review Threads" }
    ],
    "configuration": {
      "title": "MergeProof",
      "properties": { "mergeproof.cliPath": { "type": "string", "description": "Path to the MergeProof CLI executable or npm runner." } }
    }
  }
}
