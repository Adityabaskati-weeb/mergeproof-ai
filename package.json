{
  "name": "mergeproof",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "desktop:dev": "tauri dev --config apps/desktop/src-tauri/tauri.conf.json",
    "build:sidecar": "node scripts/build-cli.mjs",
    "desktop:build": "npm run build:sidecar && tauri build --config apps/desktop/src-tauri/tauri.conf.json",
    "cli": "tsx bin/mergeproof.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "commander": "^14.0.0",
    "dotenv": "^16.6.1",
    "openai": "^5.12.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/node": "^22.15.21",
    "@yao-pkg/pkg": "^6.21.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
